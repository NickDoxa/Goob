DISCORD_TOKEN=
OWNER_USER_ID=
ANTHROPIC_API_KEY=
ARM_SERIAL_PORT=/dev/ttyACM0
CAMERA_DEVICE=/dev/v4l/by-id/usb-Arducam_Technology_Co.__Ltd._Arducam_8mp_SN0001-video-index0
CLAUDE_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
DEBUG_ATTACH_FRAME=true

# --- Session memory ---
# How long to keep conversation context between turns (seconds). After this
# much silence, history clears so a stale topic doesn't poison the next
# session. Both Discord and voice queries share the same history.
SESSION_IDLE_S=300
# How many recent images to keep in history. Older images get replaced with
# a placeholder to bound vision-token cost on long conversations.
SESSION_MAX_IMAGES=3

# --- Voice frontend (optional) ---
# Off by default. Requires `pip install -e .[voice]` and the libportaudio
# system package (apt install libportaudio2 portaudio19-dev).
VOICE_ENABLED=false
# Built-in openWakeWord model. Options: alexa, hey_jarvis, hey_mycroft.
WAKE_WORD=hey_jarvis
# Empty = system default. Use a substring of the device name shown by
# `python -m sounddevice` (e.g. "USB" or "Vitade").
AUDIO_INPUT_DEVICE=
# faster-whisper model. tiny.en (~75MB) is real-time on the Uno Q;
# base.en (~145MB) is more accurate but slower.
WHISPER_MODEL=tiny.en
# Hard caps to keep a misfiring wake word from burning tokens.
MAX_AUDIO_SECONDS=15
MIN_QUERY_INTERVAL_S=5
MAX_QUERIES_PER_HOUR=30
